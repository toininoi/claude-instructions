[0.003, "o", "\u001b[?25l\u001b[90m│\u001b[39m\r\r\n\u001b[36m◆\u001b[39m  Select allowed tools for commands (optional)\r\r\n\u001b[36m│\u001b[39m  \u001b[2m\u001b[22m\u001b[36m◻\u001b[39m All tools\r\r\n\u001b[36m│\u001b[39m  │ \u001b[36m◻\u001b[39m \u001b[2mBash(git diff:*)\u001b[22m\r\r\n\u001b[36m│\u001b[39m  │ \u001b[36m◻\u001b[39m \u001b[2mBash(git status:*)\u001b[22m\r\r\n\u001b[36m│\u001b[39m  │ \u001b[36m◻\u001b[39m \u001b[2mBash(git log:*)\u001b[22m\r\r\n\u001b[36m│\u001b[39m  │ \u001b[36m◻\u001b[39m \u001b[2mBash(git rev-parse:*)\u001b[22m\r\r\n\u001b[36m│\u001b[39m  │ \u001b[36m◻\u001b[39m \u001b[2mBash(git merge-base:*)\u001b[22m\r\r\n\u001b[36m│\u001b[39m  │ \u001b[36m◻\u001b[39m \u001b[2mBash(git branch:*)\u001b[22m\r\r\n\u001b[36m│\u001b[39m  │ \u001b[36m◻\u001b[39m \u001b[2mWebFetch(domain:raw.githubusercontent.com)\u001b[22m\r\r\n\u001b[36m│\u001b[39m  └ \u001b[36m◻\u001b[39m \u001b[2mWebFetch(domain:api.github.com)\u001b[22m\r\r\n\u001b[36m└\u001b[39m\r\r\n"]
